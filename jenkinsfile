pipeline {
    agent { label 'AGENT-1' }

    environment {
        course = "DevOps321"
        appversion = ""
    }

    options {
        timeout(time: 50, unit: 'SECONDS')
        disableRestartFromStage()
    }

    parameters {
        string(name: 'PERSON', defaultValue: 'Mr Jenkins', description: 'Who should I say hello to?')
        text(name: 'BIOGRAPHY', defaultValue: '', description: 'Enter some information about the person')
        booleanParam(name: 'TOGGLE', defaultValue: true, description: 'Toggle this value')
        choice(name: 'CHOICE', choices: ['One', 'Two', 'Three'], description: 'Pick something')
        password(name: 'PASSWORD', defaultValue: 'SECRET', description: 'Enter a password')
    }

    stages {

        stage('Run nodejs') {
            steps {
                script {
                    def packagejson = readJSON file: 'package.json'
                    env.appversion = packagejson.version
                    echo "appversion ${env.appversion}"
                }

                echo "Hello Build"
                echo "${course}"
            }
        }

        stage('Install Dependencies') {
            steps {
                sh """
                npm install
                """
            }
        }

        stage('Docker build images') {
            steps {
                script {

                    withAWS(region: 'us-east-1', credentials: 'aws credentials') {

                        sh """
                        echo Logged into AWS

                        aws ecr get-login-password --region us-east-1 | docker login --username AWS --password-stdin 718311990774.dkr.ecr.us-east-1.amazonaws.com

                        docker build -t roboshop/catalogue:${env.appversion} .

                        docker images

                        docker push 718311990774.dkr.ecr.us-east-1.amazonaws.com/roboshop/catalogue:${env.appversion}
                        """

                    }

                }
            }
        }

        stage('Deploy') {
            steps {

                input message: "Should we continue?",
                      ok: "Yes, we should.",
                      submitter: "alice,bob",
                      parameters: [
                        string(name: 'PERSON', defaultValue: 'Mr Jenkins', description: 'Who should I say hello to?')
                      ]

                sh """
                echo "Hello Deploy"
                echo "${course}"
                """
            }
        }

    }

    post {
        always {
            echo 'I will always say Hello again!'
            cleanWs()
        }

        success {
            echo 'I will run if success'
        }

        failure {
            echo 'I will run if failure'
        }

        aborted {
            echo 'pipeline is aborted'
        }
    }
}