pipeline {
    agent { label 'AGENT-1' }

    environment {
        course = "DevOps321"
        appversion = ""
        AWS_ACCOUNT = "718311990774"
        AWS_REGION = "us-east-1"
        REPO = "roboshop/catalogue"
        SONARQUBE_ENV = "sonarqube"
    }

    stages {

        stage('Read Version') {
            steps {
                script {
                    def packagejson = readJSON file: 'package.json'
                    env.appversion = packagejson.version ?: "1.0.0"
                    echo "Application Version: ${env.appversion}"
                }

                echo "Hello Build"
                echo "${course}"
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                npm install
                '''
            }
        }

        stage('Testing') {
            steps {
                sh '''
                npm test
                echo "Testing completed"
                '''
            }
        }

        stage('SonarQube Scan') {
            steps {
                script {
                    def scannerHome = tool 'sonar-scanner'
                    withSonarQubeEnv("${SONARQUBE_ENV}") {
                        sh """
                        ${scannerHome}/bin/sonar-scanner \
                        -Dsonar.projectKey=catalogue \
                        -Dsonar.projectName=catalogue \
                        -Dsonar.sources=.
                        """
                    }
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                script {

                    withAWS(region: "${AWS_REGION}", credentials: 'aws credentials') {

                        sh """
                        echo "Login to AWS ECR"

                        aws ecr get-login-password --region ${AWS_REGION} | \
                        docker login --username AWS --password-stdin ${AWS_ACCOUNT}.dkr.ecr.${AWS_REGION}.amazonaws.com

                        echo "Building Docker Image"

                        docker build -t ${REPO}:${env.appversion} .

                        docker tag ${REPO}:${env.appversion} \
                        ${AWS_ACCOUNT}.dkr.ecr.${AWS_REGION}.amazonaws.com/${REPO}:${env.appversion}

                        echo "Pushing Docker Image"

                        docker push ${AWS_ACCOUNT}.dkr.ecr.${AWS_REGION}.amazonaws.com/${REPO}:${env.appversion}

                        docker images
                        """
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                echo "Hello Deploy"
                echo "${course}"
                '''
            }
        }

    }

    post {
        always {
            echo 'I will always say Hello again!'
            cleanWs()
        }

        success {
            echo 'Pipeline completed successfully'
        }

        failure {
            echo 'Pipeline failed'
        }

        aborted {
            echo 'Pipeline was aborted'
        }
    }
}